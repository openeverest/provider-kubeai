# Copy to dev/.env and adjust as needed. All values are optional; defaults are
# shown. dev/.env is git-ignored.

# --- OpenEverest core ---
# Install the released OpenEverest core. Set to false to run the core from
# source in a separate Tilt instance (see dev/README.md).
INSTALL_OPENEVEREST=true
# Pin the core chart version. REQUIRED while v2 is pre-release (Helm "latest"
# skips pre-release tags). Defaults to the version this provider builds against.
OPENEVEREST_VERSION=2.0.0-dev.1
OPENEVEREST_HELM_REPO=https://openeverest.github.io/helm-charts/
EVEREST_NAMESPACE=everest-system

# --- KubeAI operator ---
# Install the KubeAI operator into PROVIDER_NAMESPACE. Set to false if KubeAI
# is already present in the cluster.
INSTALL_KUBEAI=true
# Pin the KubeAI chart version. Empty = latest.
KUBEAI_VERSION=
KUBEAI_HELM_REPO=https://www.kubeai.org
# Optional extra values file for KubeAI (e.g. GPU resource profiles):
#   KUBEAI_EXTRA_VALUES=deploy/kubeai/values-gpu.yaml
KUBEAI_EXTRA_VALUES=

# --- Provider ---
# Namespace for KubeAI, the provider, and Instances (they must share a ns).
PROVIDER_NAMESPACE=default
# Go build flags for the provider binary.
PROVIDER_BUILD_ENV=CGO_ENABLED=0 GOOS=linux

# --- Everest UI ---
UI_ADMIN_PASSWORD=admin

# --- External cluster / registry (advanced) ---
# Allow a non-local kube context (k3d/kind/minikube are allowed automatically).
K8S_CONTEXT=
# Push dev images to an external registry instead of the local one.
DOCKER_REGISTRY_URL=
